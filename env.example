# =====================================================================
# Timelock Backend 环境变量
# 复制为 .env 后填入实际值。.env 切勿提交到 git！
#
# 这里只放两类内容：
#   1. 敏感数据：密码、密钥、API Key、SMTP 凭证等
#   2. 跨环境差异项：本地 vs docker 不同的 host
#
# 其它"非敏感、跨环境基本不变"的配置请在 config.yaml 中维护。
# 同名 env 优先级 > config.yaml。
# =====================================================================

# ---------------------------------------------------------------------
# 数据库（敏感）
# ---------------------------------------------------------------------
# docker 部署时 docker-compose 会自动把 DATABASE_HOST 覆盖为 postgres，
# 本地开发保持默认 localhost 即可。
POSTGRES_DB=timelocker_db
POSTGRES_USER=timelocker
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_PASSWORD=change_me_strong_password   # 与 POSTGRES_PASSWORD 一致；后端用这个连库

# ---------------------------------------------------------------------
# Redis（敏感）
# ---------------------------------------------------------------------
REDIS_PASSWORD=

# ---------------------------------------------------------------------
# JWT（敏感，>= 32 字符随机串）
# ---------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ---------------------------------------------------------------------
# RPC（敏感）
# ---------------------------------------------------------------------
RPC_ALCHEMY_API_KEY=
RPC_INFURA_API_KEY=

# ---------------------------------------------------------------------
# 邮件 SMTP（敏感）
# ---------------------------------------------------------------------
EMAIL_SMTP_USERNAME=notifications@timelock.tech
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_EMAIL=notifications@timelock.tech

# ---------------------------------------------------------------------
# 备份脚本（仅 docker-compose 的 backup-scheduler 用）
# ---------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
MAX_BACKUPS=50
BACKUP_PREFIX=timelocker_auto
